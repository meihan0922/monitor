  "description": "",
  "main": "index.js",
  "scripts": {
    "lint": "eslint",
    "spellcheck": "cspell lint --dot --gitignore --color --cache --show-suggestions \"(packages|apps)/**/*.@(html|js|cjs|mjs|ts|tsx|css|scss|md)\"",
    "spellcheck:staged": "cspell lint --dot --gitignore --color --cache --show-suggestions",
    "commit": "czg",
    "test": "echo \"Error: no test specified\" && exit 1",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/meihan0922/monitor.git"
  },
  "lint-staged": {
    "*.{md,json}": [
      "pnpm spellcheck:staged",
      "prettier --cache --write --no-error-on-unmatched-pattern"
    ],
    "*.{css,less}": [
      "prettier --cache --write"
    ],
    "*.{js,jsx}": [
      "pnpm spellcheck:staged",
      "eslint --fix",
      "prettier --cache --write"
    ],
    "*.{ts,tsx}": [
      "pnpm spellcheck:staged",
      "eslint --fix",
      "prettier --cache --parser=typescript --write"
    ]
  },
  "keywords": [],
